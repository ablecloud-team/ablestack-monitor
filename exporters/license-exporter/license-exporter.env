# Upstream source.
LICENSE_EXPORTER_SOURCE=host_api

# Host-local API settings. license-exporter runs on each host and calls its own 8080 API.
LICENSE_EXPORTER_API_URL=https://127.0.0.1:8080/api/v1/license/isLicenseExpired

# Skip TLS verification for self-signed host API certs.
LICENSE_EXPORTER_INSECURE_SKIP_VERIFY=true

# Optional extra header. Example:
# LICENSE_EXPORTER_AUTH_HEADER=Authorization: Bearer <token>
LICENSE_EXPORTER_AUTH_HEADER=

# Exporter bind settings
LICENSE_EXPORTER_LISTEN_ADDRESS=0.0.0.0
LICENSE_EXPORTER_PORT=3007
LICENSE_EXPORTER_METRICS_PATH=/metrics

# HTTP client timeout
LICENSE_EXPORTER_TIMEOUT_SECONDS=10

# Optional instance label
LICENSE_EXPORTER_INSTANCE=host-license

# Logging
LICENSE_EXPORTER_LOG_LEVEL=INFO
